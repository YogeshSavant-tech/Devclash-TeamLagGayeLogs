<%- include("partials/header.ejs") %>

  <div class="container">
    <section class="py-5 animate-on-scroll">
      <div class="row flex-lg-row-reverse align-items-center g-5 py-5">
        <div class="col-10 col-sm-8 col-lg-6 mx-auto">
          <img src="/images/zoom.jpg" onerror="this.src='https://placehold.co/800x600?text=App+Interface'"
            class="d-block mx-lg-auto img-fluid rounded-4 shadow-lg" alt="Briefly app interface">
        </div>
        <div class="col-lg-6">
          <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill fw-semibold">
            <i class="bi bi-stars"></i> AI-powered Intelligence
          </span>
          <h1 class="display-4 fw-bold text-dark mb-4 lh-sm">Simplify your workflow with <span
              class="text-primary">Briefly</span></h1>
          <p class="lead text-muted mb-4">Keep your tasks, notes, and goals organized without the clutter. Briefly
            silently captures what matters in your meetings.</p>
          <div class="d-grid gap-3 d-md-flex mt-4">
            <a href="/login" class="btn btn-primary btn-lg px-4 rounded-pill">Get Started Free</a>
            <a href="/working" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">See how it works</a>
          </div>
        </div>
      </div>
    </section>

      <section class="py-5 my-5 animate-on-scroll">
        <div class="text-center mb-5">
          <p class="section-label text-uppercase">What Briefly Does</p>
          <h2 class="display-6 fw-bold">Three things that actually matter</h2>
        </div>

        <div class="row g-4 justify-content-center">
          <div class="col-md-6 col-lg-4 d-flex">
            <div class="section-card p-4 rounded-4 w-100 text-center">
              <div class="icon-box mx-auto mb-4"><i class="bi bi-list-check"></i></div>
              <h3 class="fs-5 fw-bold mb-3">Live Action Items</h3>
              <p class="text-muted">Tasks are captured and tracked automatically the moment they are mentioned.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4 d-flex">
            <div class="section-card p-4 rounded-4 w-100 text-center">
              <div class="icon-box mx-auto mb-4"><i class="bi bi-file-earmark-text"></i></div>
              <h3 class="fs-5 fw-bold mb-3">Real-Time Summary</h3>
              <p class="text-muted">Watch the meeting notes construct themselves continuously while you speak.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4 d-flex">
            <div class="section-card p-4 rounded-4 w-100 text-center">
              <div class="icon-box mx-auto mb-4"><i class="bi bi-diagram-3"></i></div>
              <h3 class="fs-5 fw-bold mb-3">Meeting Memory</h3>
              <p class="text-muted">Track recurring discussions and unresolved topics across multiple meetings.</p>
            </div>
          </div>
        </div>
      </section>
    </div>

  <section class="py-4 bg-white animate-on-scroll">
    <div class="container py-3">
      <div class="row align-items-center g-4 justify-content-between">

        <div class="col-lg-5 pe-lg-4">
          <span class="badge bg-primary bg-opacity-10 text-primary text-uppercase px-2 py-1 rounded-pill mb-3 fw-bold"
            style="letter-spacing: 0.5px; font-size: 0.7rem;">
            How does it work?
          </span>
          <h2 class="fw-bold mb-4 text-dark" style="font-size: 2rem;">Honestly, it just works.</h2>

          <div class="mb-3">
            <div class="text-primary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">Step 1
            </div>
            <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">Silent Capture</h5>
            <p class="text-muted small mb-0">Runs quietly in the background. No bots interrupting your call.</p>
            <div class="border-top border-primary opacity-25 my-3" style="border-style: dotted; border-width: 2px;"></div>
          </div>

          <div class="mb-3">
            <div class="text-primary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">Step 2
            </div>
            <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">Live Processing</h5>
            <p class="text-muted small mb-0">Instantly detects decisions, tasks, and key context as you speak.</p>
            <div class="border-top border-primary opacity-25 my-3" style="border-style: dotted; border-width: 2px;"></div>
          </div>

          <div>
            <div class="text-primary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">Step 3
            </div>
            <h5 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">Structured Memory</h5>
            <p class="text-muted small mb-0">Delivers ready-to-use summaries and organizes action items for your team.</p>
          </div>
        </div>

        <div class="col-lg-6 mt-5 mt-lg-0">
          <div class="integration-hub mx-auto">

            <div class="hub-center">
              <img src="/images/logo.png" alt="Website Logo" style="width: 6rem; height: 6rem; object-fit: cover; border-radius: 50%;">
            </div>

            <div class="hub-node node-1 bg-primary text-white"><i class="bi bi-record-circle"></i> Records</div>
            <div class="hub-node node-2 bg-white text-dark border"><i class="bi bi-file-earmark-text"></i> Summaries</div>
            <div class="hub-node node-3 bg-white text-dark border"><i class="bi bi-calendar-event"></i> Schedules</div>
            <div class="hub-node node-4 text-white" style="background: var(--dark);"><i class="bi bi-chat-text"></i>
              Transcripts</div>
            <div class="hub-node node-5 bg-white text-dark border"><i class="bi bi-speedometer2"></i>Efficient</div>

          </div>
        </div>

      </div>
    </div>
  </section>
  <%- include("partials/footer.ejs") %>